# ============================================================
# JobBridge Frontend — Production Environment (Vercel)
# Set these values in Vercel → Project → Settings → Environment Variables
# ============================================================

# Backend API base URL (your Render service URL — NO trailing slash)
VITE_API_BASE_URL=https://jobbridge-backend.onrender.com

# Socket.io server URL (same host as backend)
VITE_SOCKET_URL=https://jobbridge-backend.onrender.com

# Supabase (public anon key only — safe for frontend)
VITE_SUPABASE_URL=https://dlexnkpbudtjwzobiumr.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
