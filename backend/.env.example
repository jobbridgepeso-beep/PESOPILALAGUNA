# ============================================================
# JobBridge Backend — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ============================================================

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-string

# --- JWT ---
JWT_SECRET_KEY=replace-with-another-long-random-string

# --- Supabase ---
# Public anon key (used by the frontend and for non-privileged queries)
SUPABASE_URL=https://dlexnkpbudtjwzobiumr.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Service role key (server-side only — bypasses RLS; keep secret)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# PostgreSQL connection (Settings → Database → Session pooler URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- Gmail SMTP (Flask-Mail) ---
MAIL_USERNAME=your-gmail-address@gmail.com
# Use a Gmail App Password, not your account password
MAIL_PASSWORD=your-gmail-app-password

# --- Redis ---
# Format: redis://:password@host:port/db_number
REDIS_URL=redis://localhost:6379/0

# --- Dialogflow ES ---
DIALOGFLOW_PROJECT_ID=your-dialogflow-project-id

# --- Google Cloud credentials (Vision API + Dialogflow) ---
# Absolute path to the service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# --- Optional: override default port ---
PORT=5000
